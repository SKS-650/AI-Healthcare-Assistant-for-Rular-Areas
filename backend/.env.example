# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
APP_BASE_URL=http://localhost:8000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthcare_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@healthcareai.com

# ─── SMS ──────────────────────────────────────────────────────────────────────
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
