<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration
  ─────────────────────────────────────────────────────────────────────────────
  Allows plain HTTP traffic to the local WiFi backend server during
  development (192.168.254.5:8000).  In production this file should be
  replaced with a version that restricts cleartext to only your domain and
  enforces HTTPS everywhere else.
-->
<network-security-config>

    <!-- Allow cleartext (HTTP) traffic to the LAN backend server -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Physical device on WiFi → laptop server -->
        <domain includeSubdomains="false">192.168.254.5</domain>
        <!-- Android emulator host alias -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- localhost for web / desktop builds -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- All other traffic must use HTTPS (production safety net) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
